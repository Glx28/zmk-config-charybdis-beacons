        { "keys": "Ctrl+W", "action": "Close tab", "frequency": "high", "modifiers": ["Ctrl"], "base_key": "W", "context": "always" },
        { "keys": "Ctrl+Tab", "action": "Next tab", "frequency": "high", "modifiers": ["Ctrl"], "base_key": "Tab", "context": "always" },
        { "keys": "Ctrl+Shift+Tab", "action": "Previous tab", "frequency": "medium", "modifiers": ["Ctrl", "Shift"], "base_key": "Tab", "context": "always" },
        { "keys": "Ctrl+P", "action": "Print", "frequency": "low", "modifiers": ["Ctrl"], "base_key": "P", "context": "always" }
      ]
    },
