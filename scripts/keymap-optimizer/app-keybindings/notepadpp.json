        { "keys": "Ctrl+Shift+W", "action": "Word wrap toggle", "frequency": "medium", "modifiers": ["Ctrl", "Shift"], "base_key": "W", "context": "always" },
        { "keys": "Alt+0", "action": "Fold all", "frequency": "low", "modifiers": ["Alt"], "base_key": "0", "context": "text-editing" },
        { "keys": "Alt+Shift+0", "action": "Unfold all", "frequency": "low", "modifiers": ["Alt", "Shift"], "base_key": "0", "context": "text-editing" }
      ]
