        { "keys": "F2", "action": "Next bookmark", "frequency": "medium", "modifiers": [], "base_key": "F2", "context": "text-editing" },
        { "keys": "Shift+F2", "action": "Previous bookmark", "frequency": "low", "modifiers": ["Shift"], "base_key": "F2", "context": "text-editing" }
      ]
