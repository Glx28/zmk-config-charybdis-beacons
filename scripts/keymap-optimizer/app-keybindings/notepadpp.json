        { "keys": "F3", "action": "Find next", "frequency": "high", "modifiers": [], "base_key": "F3", "context": "always" },
        { "keys": "Shift+F3", "action": "Find previous", "frequency": "medium", "modifiers": ["Shift"], "base_key": "F3", "context": "always" },
        { "keys": "Ctrl+Shift+F", "action": "Find in files", "frequency": "medium", "modifiers": ["Ctrl", "Shift"], "base_key": "F", "context": "always" },
