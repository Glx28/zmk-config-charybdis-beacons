{
  "name": "Windows Norwegian (nb-NO)",
  "firmware_model": "ZMK sends US HID scancodes. Windows Norwegian layout maps them to NO glyphs. Only ø/æ/å use coach labels on base; all other keys keep US/international scancodes.",
  "coach_match_order": ["event.code", "norwegian_event.key", "visual_label", "us_event.key"],
  "programming_on_norwegian_windows": {
    "summary": "HID scancodes are layout-independent; Windows Norwegian maps several US programming keys to NO letters.",
    "scancode_to_norwegian_glyph": {
      "SemiColon and Colon": "ø (not ;)",
      "Left Apos and Double": "æ (not ')",
      "Left Brace": "å (not [)",
      "Left Bracket": "å (same [ scancode as Left Brace)",
      "Right Bracket": "^ dead key (not ])",
      "Minus": "+ unshifted on Norwegian minus key"
    },
    "english_punctuation_options": [
      "Win+Space or F16 (L4) to switch Windows to US English while coding",
      "Layer 1 bracket keys still highlight correctly in the coach via event.code; output follows Norwegian mapping unless layout is English"
    ]
  },
  "norwegian_base_exceptions": [
    { "x": 11, "y": 2, "label": "ø", "zmk_parameter": "SemiColon and Colon", "event_code": "Semicolon" },
    { "x": 12, "y": 2, "label": "æ", "zmk_parameter": "Left Apos and Double", "event_code": "Quote" },
    { "x": 12, "y": 1, "label": "å", "zmk_parameter": "Left Brace", "event_code": "BracketLeft" }
  ],
  "zmk_parameter_aliases": {
    "SemiColon": ["SemiColon", "SemiColon and Colon"],
    "Left Apos and Double": ["Left Apos and Double", "Apostrophe", "Keyboard Apostrophe"],
    "Left Brace": ["Left Brace", "Left Bracket"],
    "Right Bracket": ["Right Bracket", "Right Brace"],
    "Backslash and Pipe": ["Backslash and Pipe", "Backslash"],
    "Comma and LessThan": ["Comma and LessThan", "Comma"],
    "ForwardSlash and QuestionMark": ["ForwardSlash and QuestionMark", "ForwardSlash"],
    "Period": ["Period", "Period and GreaterThan"],
    "Spacebar": ["Spacebar", "Space"],
    "Return": ["Return", "Return Enter", "Enter"],
    "Grave": ["Grave", "Grave Accent and Tilde"]
  },
  "event_key_to_zmk": {
    "ø": "SemiColon",
    "Ø": "SemiColon",
    "æ": "Left Apos and Double",
    "Æ": "Left Apos and Double",
