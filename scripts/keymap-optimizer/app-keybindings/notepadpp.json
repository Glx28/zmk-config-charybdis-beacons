        { "keys": "Tab", "action": "Indent", "frequency": "constant", "modifiers": [], "base_key": "Tab", "context": "text-editing" },
        { "keys": "Shift+Tab", "action": "Outdent", "frequency": "high", "modifiers": ["Shift"], "base_key": "Tab", "context": "text-editing" },
