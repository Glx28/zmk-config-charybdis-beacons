/*
Bluetooth coach beacon macro template.

This file is intentionally a template/reference include. Wire these behaviors
into the active firmware source only after confirming that source matches the
final v1.8 ZMK Studio layout.

The beacons use rare HID chords that AutoHotkey swallows:
- Ctrl+Alt+Shift+F13..F24 for held/locked layer changes.
- Ctrl+Alt+GUI+F13..F15 for pointer-travel/recovery changes.
- Ctrl+Alt+GUI+F16..F23 for extra dynamic holds/toggles.
- Ctrl+Shift+GUI+F13..F18 for extra dynamic holds.
- Ctrl+Alt+Shift+GUI+F13..F22 for generic dynamic toggles L1..L10.

BLE timing is conservative to avoid grouped or reordered host notifications.
*/

coach_l1_hold: coach_l1_hold {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <40>;
            tap-ms = <40>;
            bindings =
                <&macro_tap &kp LC(LA(LS(F13)))>,
                <&macro_press &mo 1>,
                <&macro_pause_for_release>,
                <&macro_release &mo 1>,
                <&macro_tap &kp LC(LA(LS(F14)))>;
        };

        coach_l2_hold: coach_l2_hold {
            compatible = "zmk,behavior-macro";
