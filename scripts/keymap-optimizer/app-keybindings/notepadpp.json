{
  "id": "notepadpp",
  "name": "Notepad++",
  "version": "8.6+",
  "platform": "windows",
  "categories": [
    {
      "name": "File",
      "shortcuts": [
        { "keys": "Ctrl+N", "action": "New file", "frequency": "medium", "modifiers": ["Ctrl"], "base_key": "N", "context": "always" },
        { "keys": "Ctrl+O", "action": "Open file", "frequency": "medium", "modifiers": ["Ctrl"], "base_key": "O", "context": "always" },
        { "keys": "Ctrl+S", "action": "Save", "frequency": "constant", "modifiers": ["Ctrl"], "base_key": "S", "context": "always" },
